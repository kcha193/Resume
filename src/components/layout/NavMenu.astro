---
const navItems = [
  { label: 'Snapshot',     href: '#about' },
  { label: 'Experience',   href: '#experience' },
  { label: 'Projects',     href: '#projects' },
  { label: 'Skills',       href: '#skills' },
  { label: 'Publications', href: '#publications' },
  { label: 'Education',    href: '#education' },
  { label: 'Contact',      href: '#contact' },
];
---

<!-- Desktop nav: fully static, zero JS -->
<nav aria-label="Site navigation" class="hidden md:block">
  <ul class="flex items-center gap-1 rounded-full border border-zinc-950/10 bg-white/55 p-1 text-sm text-zinc-600 shadow-sm dark:border-white/10 dark:bg-white/5 dark:text-zinc-300">
    {navItems.map(({ label, href }) => (
      <li>
        <a href={href} class="rounded-full px-3 py-1.5 transition-colors hover:bg-zinc-950/5 hover:text-zinc-950 dark:hover:bg-white/10 dark:hover:text-zinc-50 no-underline">
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<!-- Mobile hamburger -->
<button
  id="nav-toggle"
  aria-label="Open menu"
  aria-expanded="false"
  aria-controls="mobile-nav"
  class="md:hidden rounded-md border border-zinc-950/10 bg-white/65 p-2 text-zinc-600 shadow-sm transition-colors hover:text-zinc-950 dark:border-white/10 dark:bg-white/5 dark:text-zinc-300 dark:hover:text-zinc-50"
>
  <!-- Hamburger icon (shown when closed) -->
  <svg id="nav-icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="3" y1="6"  x2="21" y2="6" />
    <line x1="3" y1="12" x2="21" y2="12" />
    <line x1="3" y1="18" x2="21" y2="18" />
  </svg>
  <!-- Close icon (shown when open) -->
  <svg id="nav-icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
    <line x1="18" y1="6"  x2="6"  y2="18" />
    <line x1="6"  y1="6"  x2="18" y2="18" />
  </svg>
</button>

<!-- Mobile dropdown -->
<nav
  id="mobile-nav"
  aria-label="Mobile navigation"
  class="md:hidden hidden absolute left-0 right-0 top-16 z-50 border-b border-zinc-950/10 bg-[#f8f7f2]/96 backdrop-blur-xl dark:border-white/10 dark:bg-zinc-950/96"
>
  <ul class="max-w-6xl mx-auto px-4 py-4 space-y-1">
    {navItems.map(({ label, href }) => (
      <li>
        <a
          href={href}
          class="block rounded-md px-3 py-2.5 text-sm font-semibold text-zinc-700 transition-colors hover:bg-zinc-950/5 hover:text-zinc-950 dark:text-zinc-300 dark:hover:bg-white/10 dark:hover:text-zinc-50 no-underline"
        >
          {label}
        </a>
      </li>
    ))}
    <li class="pt-2 pb-1">
      <a
        href="/resume.html"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-md bg-[var(--brand)] px-3 py-2.5 text-sm font-semibold text-zinc-950 transition-opacity hover:opacity-95 no-underline"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download Resume
      </a>
    </li>
  </ul>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const nav    = document.getElementById('mobile-nav')!;
  const iconOpen  = document.getElementById('nav-icon-open')!;
  const iconClose = document.getElementById('nav-icon-close')!;

  function openMenu() {
    nav.classList.remove('hidden');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close menu');
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
  }

  function closeMenu() {
    nav.classList.add('hidden');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open menu');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
  }

  toggle.addEventListener('click', () => {
    nav.classList.contains('hidden') ? openMenu() : closeMenu();
  });

  // Close when a nav link is clicked
  nav.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
</script>
