---
const navItems = [
  { label: 'About',        href: '#about' },
  { label: 'Experience',   href: '#experience' },
  { label: 'Projects',     href: '#projects' },
  { label: 'Skills',       href: '#skills' },
  { label: 'Publications', href: '#publications' },
  { label: 'Education',    href: '#education' },
  { label: 'Contact',      href: '#contact' },
];
---

<!-- Desktop nav: fully static, zero JS -->
<nav aria-label="Site navigation" class="hidden md:block">
  <ul class="flex items-center gap-6 text-sm text-zinc-500 dark:text-zinc-400">
    {navItems.map(({ label, href }) => (
      <li>
        <a href={href} class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<!-- Mobile hamburger -->
<button
  id="nav-toggle"
  aria-label="Open menu"
  aria-expanded="false"
  aria-controls="mobile-nav"
  class="md:hidden p-2 rounded-lg text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors"
>
  <!-- Hamburger icon (shown when closed) -->
  <svg id="nav-icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="3" y1="6"  x2="21" y2="6" />
    <line x1="3" y1="12" x2="21" y2="12" />
    <line x1="3" y1="18" x2="21" y2="18" />
  </svg>
  <!-- Close icon (shown when open) -->
  <svg id="nav-icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
    <line x1="18" y1="6"  x2="6"  y2="18" />
    <line x1="6"  y1="6"  x2="18" y2="18" />
  </svg>
</button>

<!-- Mobile dropdown -->
<nav
  id="mobile-nav"
  aria-label="Mobile navigation"
  class="md:hidden hidden absolute top-14 left-0 right-0 bg-zinc-50/95 dark:bg-zinc-950/95 backdrop-blur-md border-b border-zinc-100 dark:border-zinc-800 z-50"
>
  <ul class="max-w-6xl mx-auto px-4 py-4 space-y-1">
    {navItems.map(({ label, href }) => (
      <li>
        <a
          href={href}
          class="block py-2.5 px-3 rounded-lg text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:text-[var(--brand)] transition-colors"
        >
          {label}
        </a>
      </li>
    ))}
    <li class="pt-2 pb-1">
      <a
        href="/resume.html"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 py-2.5 px-3 rounded-lg text-sm font-semibold text-zinc-900 bg-[var(--brand)] hover:opacity-90 transition-opacity"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download Resume
      </a>
    </li>
  </ul>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const nav    = document.getElementById('mobile-nav')!;
  const iconOpen  = document.getElementById('nav-icon-open')!;
  const iconClose = document.getElementById('nav-icon-close')!;

  function openMenu() {
    nav.classList.remove('hidden');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close menu');
    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
  }

  function closeMenu() {
    nav.classList.add('hidden');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open menu');
    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
  }

  toggle.addEventListener('click', () => {
    nav.classList.contains('hidden') ? openMenu() : closeMenu();
  });

  // Close when a nav link is clicked
  nav.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
</script>
