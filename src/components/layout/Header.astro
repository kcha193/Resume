---
import ThemeToggle from './ThemeToggle.astro';
import NavMenu from './NavMenu.astro';
---

<header class="sticky top-0 z-50 border-b border-zinc-950/10 bg-[#f8f7f2]/82 backdrop-blur-xl dark:border-white/10 dark:bg-zinc-950/82">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
    <a
      href="/"
      class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-zinc-950/10 bg-white/70 text-sm font-black text-zinc-950 shadow-sm transition-colors hover:border-[var(--brand)] hover:text-zinc-950 dark:border-white/10 dark:bg-white/5 dark:text-zinc-50 dark:hover:text-white no-underline"
      aria-label="KC — Kevin Chang home"
    >
      KC
    </a>

    <NavMenu />

    <div class="flex items-center gap-2">
      <a
        href="/resume.html"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex items-center gap-1.5 rounded-md bg-[var(--brand)] px-3.5 py-2 text-sm font-semibold text-zinc-950 shadow-sm shadow-[var(--brand-glow)] transition-transform hover:-translate-y-0.5 hover:opacity-95 no-underline"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Resume
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
