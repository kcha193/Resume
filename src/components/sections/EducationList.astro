---
interface Props {
  items: Array<{
    degree: string;
    university: string;
    year: number;
  }>;
  languages: Array<{ name: string; level: string }>;
  interests: string[];
}

const { items, languages, interests } = Astro.props;
---

<section
  id="education"
  class="section-shell bg-white dark:bg-zinc-900/55"
  aria-labelledby="education-heading"
>
  <div class="section-inner">
    <div class="grid gap-6 lg:grid-cols-[1.25fr_0.75fr]">
      <div class="rounded-lg border border-zinc-950/10 bg-[#f8f7f2]/70 p-6 shadow-sm dark:border-white/10 dark:bg-white/[0.035]">
        <p class="eyebrow">Academic Foundation</p>
        <h2 id="education-heading" class="section-title !text-3xl">
          Education
        </h2>
        <ul class="mt-8 space-y-5">
          {items.map(item => (
            <li class="flex gap-4 rounded-md border border-zinc-950/10 bg-white/65 p-4 dark:border-white/10 dark:bg-zinc-950/35">
              <span class="min-w-[3.5rem] pt-0.5 font-mono text-sm font-black text-[var(--link)] dark:text-[var(--brand)]">
                {item.year}
              </span>
              <div>
                <p class="text-sm font-black text-zinc-950 dark:text-zinc-50">
                  {item.degree}
                </p>
                <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                  {item.university}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-lg border border-zinc-950/10 bg-[#f8f7f2]/70 p-6 shadow-sm dark:border-white/10 dark:bg-white/[0.035]">
        <p class="eyebrow">Personal Context</p>
        <div class="mt-8">
          <h3 class="mb-3 text-xs font-mono uppercase text-zinc-500 dark:text-zinc-400">
            Languages
          </h3>
          <ul class="space-y-2">
            {languages.map(lang => (
              <li class="flex items-center justify-between rounded-md border border-zinc-950/10 bg-white/65 px-3 py-2 text-sm dark:border-white/10 dark:bg-zinc-950/35">
                <span class="font-semibold text-zinc-800 dark:text-zinc-200">{lang.name}</span>
                <span class="font-mono text-xs text-zinc-500 dark:text-zinc-400">{lang.level}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="mt-8">
          <h3 class="mb-3 text-xs font-mono uppercase text-zinc-500 dark:text-zinc-400">
            Interests
          </h3>
          <div class="flex flex-wrap gap-2">
            {interests.map(interest => (
              <span class="rounded-full border border-zinc-950/10 bg-white/65 px-3 py-1.5 text-xs font-semibold text-zinc-600 dark:border-white/10 dark:bg-zinc-950/35 dark:text-zinc-300">
                {interest}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
