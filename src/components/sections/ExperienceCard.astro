---
import Badge from '../ui/Badge.astro';
import { formatDate, boldMarkdown } from '../../lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'experience'>;
  isLast: boolean;
}

const { entry, isLast } = Astro.props;
const { title, company, location, startDate, endDate, tags, highlights } = entry.data;
---

<article class:list={['group relative pl-10', !isLast && 'pb-14']}>
  <!-- Timeline line -->
  {!isLast && (
    <div
      class="absolute left-[5px] top-4 bottom-0 w-px bg-zinc-200 dark:bg-zinc-800"
      aria-hidden="true"
    />
  )}

  <!-- Timeline dot -->
  <div
    class="absolute left-0 top-1 w-3 h-3 rounded-full bg-[var(--brand)] ring-4 ring-white dark:ring-zinc-950 transition-transform group-hover:scale-125"
    aria-hidden="true"
  />

  <!-- Header row -->
  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
    <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 tracking-tight">
      {title}
    </h3>
    <span class="font-mono text-xs text-zinc-400">
      {formatDate(startDate)} — {formatDate(endDate)}
    </span>
  </div>

  <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-3">
    {company} · {location}
  </p>

  <!-- Tags -->
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.map(t => <Badge>{t}</Badge>)}
    </div>
  )}

  <!-- Highlights -->
  <ul class="space-y-2">
    {highlights.map(h => (
      <li
        class="relative pl-5 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400 before:absolute before:left-0 before:top-2.5 before:h-1 before:w-1 before:rounded-full before:bg-[var(--brand)]"
        set:html={boldMarkdown(h)}
      />
    ))}
  </ul>
</article>
