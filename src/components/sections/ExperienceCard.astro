---
import Badge from '../ui/Badge.astro';
import { formatDate, renderInlineMarkdown } from '../../lib/utils';
import type { CollectionEntry, RenderResult } from 'astro:content';

type AstroComponentFactory = RenderResult['Content'];

interface Props {
  entry: CollectionEntry<'experience'>;
  summary: AstroComponentFactory;
  isLast: boolean;
}

const { entry, summary: Summary, isLast } = Astro.props;
const { title, company, location, startDate, endDate, tags, highlights } = entry.data;
---

<article
  data-reveal
  class:list={[
    'group relative rounded-lg border border-zinc-950/10 bg-[var(--paper)]/70 p-5 shadow-sm transition-colors hover:border-[var(--brand)]/60 dark:border-white/10 dark:bg-white/[0.035] sm:p-6',
    isLast && 'mb-0',
  ]}>
  {!isLast && (
    <div
      class="absolute left-6 top-full hidden h-5 w-px bg-zinc-950/10 dark:bg-white/10 sm:block"
      aria-hidden="true"
    />
  )}

  <div class="grid gap-6 lg:grid-cols-[0.34fr_1fr]">
    <div>
      <div class="flex items-center gap-3">
        <span class="h-3 w-3 rounded-full bg-[var(--brand)] shadow-sm shadow-[var(--brand-glow)]" aria-hidden="true" />
        <span class="font-mono text-xs font-semibold uppercase text-zinc-500 dark:text-zinc-400">
          {formatDate(startDate)} — {formatDate(endDate)}
        </span>
      </div>
      <h3 class="mt-4 text-xl font-black leading-tight text-zinc-950 dark:text-zinc-50">
        {title}
      </h3>
      <p class="mt-2 text-sm font-semibold text-zinc-700 dark:text-zinc-300">
        {company}
      </p>
      <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
        {location}
      </p>
    </div>

    <div>
      <p class="mb-2 font-mono text-[0.68rem] font-bold uppercase tracking-[0.16em] text-zinc-500 dark:text-zinc-400">
        Role brief
      </p>
      <div class="mb-5 border-l-2 border-[var(--brand)] pl-4 text-sm font-medium leading-6 text-zinc-700 dark:text-zinc-300">
        <Summary />
      </div>

      {tags.length > 0 && (
        <div class="mb-5 flex flex-wrap gap-2">
          {tags.map(t => <Badge>{t}</Badge>)}
        </div>
      )}

      <p class="mb-3 font-mono text-[0.68rem] font-bold uppercase tracking-[0.16em] text-zinc-500 dark:text-zinc-400">
        Evidence
      </p>
      <ul class="grid gap-3">
        {highlights.map((h, index) => (
          <li
            class:list={[
              'relative rounded-md border py-3 pl-9 pr-4 text-sm leading-6 before:absolute before:left-4 before:top-5 before:h-1.5 before:w-1.5 before:rounded-full before:bg-[var(--brand)]',
              index === 0
                ? 'border-[var(--brand)]/45 bg-[color-mix(in_srgb,var(--brand)_9%,white)] font-medium text-zinc-800 dark:bg-[color-mix(in_srgb,var(--brand)_10%,#09090b)] dark:text-zinc-200'
                : 'border-zinc-950/10 bg-white/65 text-zinc-700 dark:border-white/10 dark:bg-zinc-950/35 dark:text-zinc-300',
            ]}
            set:html={renderInlineMarkdown(h)}
          />
        ))}
      </ul>
    </div>
  </div>
</article>
