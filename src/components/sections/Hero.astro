---
import { Image } from 'astro:assets';
import avatarSrc from '../../assets/avatar.jpg';

interface Props {
  profile: {
    name: string;
    tagline: string;
    summary: string;
    location: string;
    email: string;
    social: Array<{ platform: string; url: string; handle: string; icon: string }>;
  };
}
const { profile } = Astro.props;

const linkedin = profile.social.find(s => s.platform === 'linkedin');
const github   = profile.social.find(s => s.platform === 'github');

const credibilityBadges = [
  'Data Science',
  'Retail Banking',
  'Pricing Strategy',
  'Machine Learning',
  'AI / GenAI',
  'Customer Analytics',
];

const highlights = [
  { value: '12+ years', label: 'Advanced analytics, ML, and data products' },
  { value: 'ASB Bank', label: 'Retail banking, pricing, and customer intelligence' },
  { value: 'Ph.D.', label: 'Statistics and Biological Sciences' },
];
---

<section
  class="relative overflow-hidden border-b border-zinc-950/10 bg-[#f8f7f2] dark:border-white/10 dark:bg-zinc-950"
  aria-labelledby="hero-heading"
>
  <div
    class="absolute inset-0 opacity-[0.08] dark:opacity-[0.12]"
    style="background-image: linear-gradient(rgba(24,24,27,.38) 1px, transparent 1px), linear-gradient(90deg, rgba(24,24,27,.38) 1px, transparent 1px); background-size: 56px 56px;"
    aria-hidden="true"
  />
  <div class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-[var(--brand)]/16 to-transparent dark:from-[var(--brand)]/10" aria-hidden="true" />

  <div class="relative mx-auto grid min-h-[calc(100vh-4rem)] max-w-6xl items-center gap-10 px-4 py-14 sm:px-6 sm:py-20 lg:grid-cols-[1.08fr_0.92fr] lg:gap-14">

    <div>
      <p class="eyebrow mb-5">
        Senior Data Scientist · {profile.location}
      </p>
      <h1
        id="hero-heading"
        class="max-w-3xl text-5xl font-black leading-[0.98] text-zinc-950 dark:text-zinc-50 sm:text-6xl lg:text-7xl"
      >
        Banking analytics leader for pricing, AI, and customer growth.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-zinc-700 dark:text-zinc-300">
        {profile.name} is a senior data scientist translating machine learning, pricing strategy, and customer intelligence into clear commercial decisions for financial services leaders.
      </p>

      <div class="mt-7 flex flex-wrap gap-2.5" aria-label="Core expertise">
        {credibilityBadges.map(badge => (
          <span class="rounded-full border border-zinc-950/10 bg-white/70 px-3 py-1.5 text-sm font-semibold text-zinc-700 shadow-sm dark:border-white/10 dark:bg-white/5 dark:text-zinc-200">
            {badge}
          </span>
        ))}
      </div>

      <div class="mt-9 flex flex-wrap gap-3">
        <a
          href="#experience"
          class="inline-flex items-center gap-2 rounded-md bg-[var(--brand)] px-5 py-3 text-sm font-bold text-zinc-950 shadow-lg shadow-[var(--brand-glow)] transition-transform hover:-translate-y-0.5 no-underline"
        >
          View Experience
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="#projects"
          class="inline-flex items-center gap-2 rounded-md border border-zinc-950/15 bg-white/70 px-5 py-3 text-sm font-bold text-zinc-800 shadow-sm transition-colors hover:border-[var(--brand)] hover:text-zinc-950 dark:border-white/15 dark:bg-white/5 dark:text-zinc-100 dark:hover:text-white no-underline"
        >
          View Projects
        </a>
        <a
          href="/resume.html"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-zinc-950/15 bg-white/70 px-5 py-3 text-sm font-bold text-zinc-800 shadow-sm transition-colors hover:border-[var(--brand)] hover:text-zinc-950 dark:border-white/15 dark:bg-white/5 dark:text-zinc-100 dark:hover:text-white no-underline"
        >
          Resume
        </a>
        {linkedin && (
          <a
            href={linkedin.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md border border-zinc-950/15 bg-white/70 px-5 py-3 text-sm font-bold text-zinc-800 shadow-sm transition-colors hover:border-[var(--brand)] hover:text-zinc-950 dark:border-white/15 dark:bg-white/5 dark:text-zinc-100 dark:hover:text-white no-underline"
          >
            LinkedIn
          </a>
        )}
      </div>
    </div>

    <aside class="premium-card rounded-lg p-5 sm:p-6" aria-label="Profile highlights">
      <div class="flex items-center gap-4 border-b border-zinc-950/10 pb-5 dark:border-white/10">
        <Image
          src={avatarSrc}
          alt={`${profile.name} profile photo`}
          width={112}
          height={112}
          loading="eager"
          fetchpriority="high"
          class="h-20 w-20 rounded-md object-cover ring-1 ring-zinc-950/10 dark:ring-white/10 sm:h-24 sm:w-24"
        />
        <div>
          <p class="text-sm font-mono uppercase text-zinc-500 dark:text-zinc-400">
            Current profile
          </p>
          <p class="mt-2 text-xl font-black leading-tight text-zinc-950 dark:text-zinc-50">
            {profile.tagline}
          </p>
        </div>
      </div>

      <div class="mt-5 grid gap-3 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
        {highlights.map(item => (
          <div class="rounded-md border border-zinc-950/10 bg-zinc-50/80 p-4 dark:border-white/10 dark:bg-white/[0.03]">
            <p class="text-2xl font-black text-zinc-950 dark:text-zinc-50">{item.value}</p>
            <p class="mt-2 text-xs leading-5 text-zinc-600 dark:text-zinc-400">{item.label}</p>
          </div>
        ))}
      </div>

      <div class="mt-5 rounded-md border border-[var(--brand)]/40 bg-[color-mix(in_srgb,var(--brand)_12%,transparent)] p-4">
        <p class="text-xs font-mono uppercase text-zinc-500 dark:text-zinc-400">
          Positioning
        </p>
        <p class="mt-2 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
          Retail banking pricing, customer lifetime value, predictive analytics, model assurance, and stakeholder-ready insight.
        </p>
      </div>

      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href={`mailto:${profile.email}`}
          class="inline-flex items-center gap-2 rounded-md bg-zinc-950 px-4 py-2.5 text-sm font-bold text-white transition-colors hover:bg-zinc-800 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200 no-underline"
        >
          Contact Kevin
        </a>
        {github && (
          <a
            href={github.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md border border-zinc-950/15 px-4 py-2.5 text-sm font-bold text-zinc-800 transition-colors hover:border-[var(--brand)] dark:border-white/15 dark:text-zinc-100 no-underline"
          >
            GitHub
          </a>
        )}
      </div>
    </aside>
  </div>
</section>
