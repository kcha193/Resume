---
interface Props {
  tiers: Array<{
    title: string;
    items: string[];
  }>;
}

const { tiers } = Astro.props;

const tierStyles = [
  'border-[var(--brand)] bg-[color-mix(in_srgb,var(--brand)_10%,transparent)]',
  'border-zinc-950/10 bg-[var(--paper)]/70 dark:border-white/10 dark:bg-white/[0.035]',
  'border-zinc-950/10 bg-white/70 dark:border-white/10 dark:bg-zinc-950/35',
];

const tierSummaries: Record<string, string> = {
  'AI / ML / GenAI': 'Prediction, language-model analysis, and customer intelligence use cases.',
  'Pricing / Banking / Optimisation': 'Commercial analytics connected to revenue, margin, customer outcomes, and governance.',
  'Data Engineering / Analytics Platforms': 'Reusable data products and analytics surfaces that business teams can actually use.',
  'Programming / Modelling': 'Statistical depth for simulation, experimentation, and reproducible analysis.',
  'Communication / Stakeholder Impact': 'Clear recommendations for senior stakeholders, technical peers, and delivery teams.',
};
---

<section
  id="skills"
  class="section-shell bg-white dark:bg-zinc-900/55"
  aria-labelledby="skills-heading"
>
  <div class="section-inner">
    <div class="mb-12 grid gap-6 lg:grid-cols-[0.75fr_1fr] lg:items-end">
      <div>
        <p class="eyebrow">Capability Map</p>
        <h2 id="skills-heading" class="section-title" data-reveal>
          Technical depth with commercial context.
        </h2>
      </div>
      <p class="section-copy max-w-2xl lg:justify-self-end">
        Skill groups are organised for recruiters and hiring leaders: what Kevin can do, where it applies, and how it shows up in banking, pricing, analytics, and AI work.
      </p>
    </div>

    <div class="grid gap-5 lg:grid-cols-6">
      {tiers.map((tier, index) => (
        <article class:list={[
          'rounded-lg border p-5 shadow-sm',
          tierStyles[index] ?? tierStyles[1],
          index < 2 ? 'lg:col-span-3' : 'lg:col-span-2',
        ]}>
          <h3 class="text-base font-black text-zinc-950 dark:text-zinc-50">{tier.title}</h3>
          {tierSummaries[tier.title] && (
            <p class="mt-2 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
              {tierSummaries[tier.title]}
            </p>
          )}
          <div class="mt-4 flex flex-wrap gap-2">
            {tier.items.map((item, itemIndex) => (
              <span class:list={[
                'rounded-full border px-3 py-1.5 text-sm transition-colors hover:border-[var(--brand)]',
                itemIndex < 3
                  ? 'border-[var(--brand)]/45 bg-white/90 font-bold text-zinc-900 dark:bg-zinc-950/55 dark:text-zinc-100'
                  : 'border-zinc-950/10 bg-white/75 font-medium text-zinc-700 dark:border-white/10 dark:bg-zinc-950/35 dark:text-zinc-300',
              ]}>
                {item}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
