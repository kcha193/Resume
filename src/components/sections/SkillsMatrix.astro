---
interface Props {
  categories: Array<{
    title: string;
    items: string[];
  }>;
}

const { categories } = Astro.props;
---

<section
  id="skills"
  class="section-shell bg-white dark:bg-zinc-900/55"
  aria-labelledby="skills-heading"
>
  <div class="section-inner">
    <div class="mb-12 grid gap-6 lg:grid-cols-[0.75fr_1fr] lg:items-end">
      <div>
        <p class="eyebrow">Capability Map</p>
        <h2 id="skills-heading" class="section-title">
          Technical depth with commercial context.
        </h2>
      </div>
      <p class="section-copy max-w-2xl lg:justify-self-end">
        Skill groups are organised for recruiters and hiring leaders: what Kevin can do, where it applies, and how it shows up in banking, pricing, analytics, and AI work.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {categories.map((cat, index) => (
        <article class:list={[
          'rounded-lg border border-zinc-950/10 bg-[#f8f7f2]/70 p-5 shadow-sm dark:border-white/10 dark:bg-white/[0.035]',
          index === 1 && 'border-[var(--brand)]/45',
        ]}>
          <h3 class="text-sm font-black text-zinc-950 dark:text-zinc-50">
            {cat.title}
          </h3>
          <div class="mt-4 flex flex-wrap gap-2">
            {cat.items.map(item => (
              <span class="rounded-full border border-zinc-950/10 bg-white/70 px-3 py-1.5 text-sm font-medium text-zinc-700 transition-colors hover:border-[var(--brand)] dark:border-white/10 dark:bg-zinc-950/35 dark:text-zinc-300">
                {item}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
