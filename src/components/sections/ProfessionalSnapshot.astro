---
import { renderInlineMarkdown } from '../../lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  summary: string;
  experience: CollectionEntry<'experience'>[];
}

const { summary, experience } = Astro.props;
const html = renderInlineMarkdown(summary);
const currentRole = experience.find(entry => entry.data.endDate === null) ?? experience[0];

const snapshotCards = [
  {
    label: 'Experience',
    title: '12+ years in applied analytics',
    detail: 'Financial services, government policy, consulting, and research delivery.',
  },
  {
    label: 'Banking focus',
    title: 'Retail banking pricing strategy',
    detail: 'Current ASB focus on pricing models, P&L performance, customer outcomes, and conduct risk.',
  },
  {
    label: 'Customer intelligence',
    title: 'Growth and retention modelling',
    detail: 'Customer lifetime value, segmentation, churn prediction, and product recommendation systems.',
  },
  {
    label: 'AI capability',
    title: 'Machine learning and GenAI',
    detail: 'Predictive analytics plus LLM analysis of open-ended survey responses and customer sentiment.',
  },
  {
    label: 'Risk discipline',
    title: 'Model assurance background',
    detail: 'Validation experience across risk, credit, and operational models with regulatory expectations.',
  },
  {
    label: 'Leadership',
    title: 'Executive-ready communication',
    detail: 'Translates complex models into clear insights for senior stakeholders and analytics teams.',
  },
];
---

<section
  id="about"
  class="section-shell bg-[#f8f7f2] dark:bg-zinc-950"
  aria-labelledby="snapshot-heading"
>
  <div class="section-inner">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div class="lg:sticky lg:top-24">
        <p class="eyebrow">Professional Snapshot</p>
        <h2 id="snapshot-heading" class="section-title">
          What recruiters should know first.
        </h2>
        <p class="section-copy mt-6" set:html={html} />

        {currentRole && (
          <div class="premium-card mt-8 rounded-lg p-5">
            <p class="text-xs font-mono uppercase text-zinc-500 dark:text-zinc-400">
              Current role
            </p>
            <p class="mt-3 text-lg font-black text-zinc-950 dark:text-zinc-50">
              {currentRole.data.title}
            </p>
            <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
              {currentRole.data.company} · {currentRole.data.location}
            </p>
          </div>
        )}
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {snapshotCards.map((card, index) => (
          <article class:list={[
            'premium-card rounded-lg p-5',
            index === 1 && 'border-[var(--brand)]/45',
          ]}>
            <p class="text-xs font-mono uppercase text-[var(--link)] dark:text-[var(--brand)]">
              {card.label}
            </p>
            <h3 class="mt-3 text-lg font-black leading-snug text-zinc-950 dark:text-zinc-50">
              {card.title}
            </h3>
            <p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
              {card.detail}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
