---
interface Props {
  summary: string;
}
import { renderInlineMarkdown } from '../../lib/utils';
const { summary } = Astro.props;
const html = renderInlineMarkdown(summary);
---

<section
  id="about"
  class="py-12 sm:py-20 bg-zinc-950"
  aria-labelledby="about-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="max-w-[65ch]">
      <p class="text-sm font-mono text-[var(--brand)] tracking-widest uppercase mb-3">
        About
      </p>
      <h2
        id="about-heading"
        class="text-3xl font-bold text-zinc-100 mb-8"
        data-reveal
      >
        Summary
      </h2>
      <p
        class="text-base leading-relaxed text-zinc-400"
        set:html={html}
      />
    </div>
  </div>
</section>
