---
interface Props {
  profile: {
    name: string;
    email: string;
    phone: string;
    social: Array<{ platform: string; url: string; handle: string; icon: string }>;
  };
}
const { profile } = Astro.props;
const year = new Date().getFullYear();
---

<footer
  id="contact"
  class="py-16 bg-zinc-900 dark:bg-zinc-950 text-zinc-300"
  aria-labelledby="contact-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid sm:grid-cols-2 gap-10 mb-12">
      <div>
        <h2
          id="contact-heading"
          class="text-2xl font-bold text-white mb-4"
        >
          Get in Touch
        </h2>
        <div class="space-y-3 text-sm">
          <p>
            <a
              href={`mailto:${profile.email}`}
              class="hover:text-[var(--brand)] transition-colors"
            >
              {profile.email}
            </a>
          </p>
          <p>
            <a
              href={`tel:${profile.phone.replace(/\s/g, '')}`}
              class="hover:text-[var(--brand)] transition-colors"
            >
              {profile.phone}
            </a>
          </p>
        </div>
      </div>

      <div>
        <h3 class="text-xs font-mono tracking-widest uppercase text-zinc-500 mb-4">
          Find me on
        </h3>
        <div class="flex flex-wrap gap-4 text-sm">
          {profile.social.map(s => (
            <a
              href={s.url}
              target="_blank"
              rel="noopener me noreferrer"
              class="hover:text-[var(--brand)] transition-colors font-mono"
            >
              {s.handle}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="border-t border-zinc-800 pt-8 flex flex-wrap items-center justify-between gap-4 text-xs text-zinc-500">
      <p>&copy; {year} {profile.name}. All rights reserved.</p>
      <p>
        Built with{' '}
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[var(--brand)] transition-colors"
        >
          Astro
        </a>
        {' '}&amp; Tailwind CSS
      </p>
    </div>
  </div>
</footer>
