---
interface Props {
  profile: {
    name: string;
    email: string;
    social: Array<{ platform: string; url: string; handle: string; icon: string }>;
  };
}
const { profile } = Astro.props;
const year = new Date().getFullYear();
---

<footer
  id="contact"
  class="border-t border-zinc-950/10 bg-zinc-950 py-16 text-zinc-300 dark:border-white/10"
  aria-labelledby="contact-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="mb-12 rounded-lg border border-white/10 bg-white/[0.045] p-6 sm:p-8">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
        <div>
          <p class="eyebrow">Contact</p>
          <h2
            id="contact-heading"
            class="mt-4 text-3xl font-black leading-tight text-white sm:text-4xl"
          >
            Looking for senior data science leadership in banking, pricing, or AI?
          </h2>
          <p class="mt-4 max-w-2xl text-base leading-7 text-zinc-400">
            Start with the resume, connect on LinkedIn, or send a direct note.
          </p>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap lg:justify-end">
          <a
            href={`mailto:${profile.email}`}
            class="inline-flex items-center justify-center rounded-md bg-[var(--brand)] px-5 py-3 text-sm font-bold text-zinc-950 shadow-lg shadow-[var(--brand-glow)] transition-transform hover:-translate-y-0.5 no-underline"
          >
            Email Kevin
          </a>
          <a
            href="/resume.html"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-md border border-white/15 px-5 py-3 text-sm font-bold text-white transition-colors hover:border-[var(--brand)] no-underline"
          >
            View Resume
          </a>
        </div>
      </div>
    </div>

    <div class="grid gap-10 sm:grid-cols-2 mb-12">
      <div>
        <h3 class="mb-4 text-xs font-mono uppercase text-zinc-400">
          Direct contact
        </h3>
        <div class="space-y-3 text-sm font-semibold">
          <p>
            <a
              href={`mailto:${profile.email}`}
              class="hover:text-[var(--brand)] transition-colors"
            >
              {profile.email}
            </a>
          </p>
        </div>
      </div>

      <div>
        <h3 class="mb-4 text-xs font-mono uppercase text-zinc-400">
          Professional links
        </h3>
        <div class="flex flex-wrap gap-3 text-sm">
          {profile.social.map(s => (
            <a
              href={s.url}
              target="_blank"
              rel="noopener me noreferrer"
              class="rounded-md border border-white/10 px-3 py-2 font-mono transition-colors hover:border-[var(--brand)] hover:text-[var(--brand)] no-underline"
            >
              {s.handle}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-wrap items-center justify-between gap-4 text-xs text-zinc-400">
      <p>&copy; {year} {profile.name}. All rights reserved.</p>
      <p>
        Built with{' '}
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[var(--brand)] transition-colors"
        >
          Astro
        </a>
        {' '}&amp; Tailwind CSS
      </p>
    </div>
  </div>
</footer>
