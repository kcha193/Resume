---
import ProjectCard from './ProjectCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  items: CollectionEntry<'projects'>[];
}

const { items } = Astro.props;
const sorted = [...items].sort((a, b) => b.data.year - a.data.year);

const featured = sorted.filter(p => p.data.featured);
const rest     = sorted.filter(p => !p.data.featured);
---

<section
  id="projects"
  class="py-12 sm:py-20 bg-zinc-50 dark:bg-zinc-950"
  aria-labelledby="projects-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <p class="text-sm font-mono text-[var(--brand)] tracking-widest uppercase mb-3">
      Work
    </p>
    <h2
      id="projects-heading"
      class="text-3xl font-bold text-zinc-900 dark:text-zinc-100 mb-12"
    >
      Projects
    </h2>

    {featured.length > 0 && (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
        {featured.map(entry => <ProjectCard entry={entry} featured />)}
      </div>
    )}

    {rest.length > 0 && (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {rest.map(entry => <ProjectCard entry={entry} featured={false} />)}
      </div>
    )}
  </div>
</section>
