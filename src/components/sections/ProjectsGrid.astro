---
import ProjectCard from './ProjectCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  items: CollectionEntry<'projects'>[];
}

const { items } = Astro.props;
const sorted = [...items].sort((a, b) => b.data.year - a.data.year);

const featured = sorted.filter(p => p.data.featured).slice(0, 3);
const featuredIds = new Set(featured.map(p => p.id));
const rest = sorted.filter(p => !featuredIds.has(p.id));
---

<section
  id="projects"
  class="section-shell bg-[#f8f7f2] dark:bg-zinc-950"
  aria-labelledby="projects-heading"
>
  <div class="section-inner">
    <div class="mb-12 grid gap-6 lg:grid-cols-[0.75fr_1fr] lg:items-end">
      <div>
        <p class="eyebrow">Portfolio Proof</p>
        <h2 id="projects-heading" class="section-title">
          Data products with policy and business weight.
        </h2>
      </div>
      <p class="section-copy max-w-2xl lg:justify-self-end">
        Selected public work showing Kevin’s ability to turn modelling, research, and data engineering into tools that help teams make decisions.
      </p>
    </div>

    {featured.length > 0 && (
      <div class="mb-6 grid gap-5 lg:grid-cols-3">
        {featured.map(entry => <ProjectCard entry={entry} featured />)}
      </div>
    )}

    {rest.length > 0 && (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {rest.map(entry => <ProjectCard entry={entry} featured={false} />)}
      </div>
    )}
  </div>
</section>
