---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<span
  class:list={[
    'inline-flex items-center rounded px-2 py-0.5 text-xs font-bold',
    'bg-[color-mix(in_srgb,var(--brand)_22%,white)] text-zinc-900',
    'dark:bg-[color-mix(in_srgb,var(--brand)_18%,transparent)] dark:text-[var(--brand-dark)]',
    className,
  ]}
>
  <slot />
</span>
