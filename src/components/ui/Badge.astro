---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<span
  class:list={[
    'inline-flex items-center px-2 py-0.5 rounded text-xs font-medium',
    'bg-[color-mix(in_srgb,var(--brand)_15%,transparent)]',
    'text-[var(--brand)]',
    'dark:bg-[color-mix(in_srgb,var(--brand)_20%,transparent)]',
    'dark:text-[var(--brand-dark)]',
    className,
  ]}
>
  <slot />
</span>
