---
import '../styles/global.css';
import '../styles/print.css';
import { buildPersonSchema } from '../lib/seo';
import avatarImg from '../assets/avatar.jpg';

interface Props {
  profile: {
    name: string;
    tagline: string;
    seoDescription?: string;
    summary: string;
    email: string;
    location: string;
    languages: Array<{ name: string; level: string }>;
    social: Array<{ platform: string; url: string; handle: string }>;
  };
  title?: string;
  description?: string;
}

const {
  profile,
  title = `${profile.name} | ${profile.tagline}`,
  description = profile.seoDescription ?? profile.summary.replace(/\*\*/g, '').slice(0, 160),
} = Astro.props;

const siteUrl = Astro.site!.href;
const socialCardImage = new URL('/og-image.png', siteUrl).href;
const profileImage = new URL(avatarImg.src, siteUrl).href;
const jsonLd = buildPersonSchema(profile, siteUrl, profileImage, {
  worksFor: 'ASB Bank',
  alumniOf: 'University of Auckland',
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={profile.name} />
    <meta name="theme-color" content="#f8f7f2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#09090b" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialCardImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${profile.name} — ${profile.tagline}`} />
    <meta property="og:locale" content="en_NZ" />
    <meta property="og:url" content={siteUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialCardImage} />
    <meta name="twitter:image:alt" content={`${profile.name} — ${profile.tagline}`} />

    <!-- Canonical -->
    <link rel="canonical" href={siteUrl} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Font preload: Inter Variable latin subset (critical render path) -->
    <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Social rel=me -->
    {profile.social.map(s => (
      <link rel="me" href={s.url} />
    ))}

    <!-- JS feature flag: enables scroll-reveal CSS only when the observer API exists -->
    <script is:inline>if ('IntersectionObserver' in window) document.documentElement.classList.add('js');</script>

    <!-- Dark mode: set before paint to avoid FOUC -->
    <script is:inline>
      (function() {
        var stored = null;
        try {
          stored = localStorage.getItem('theme');
        } catch (e) {}
        var pref = stored || 'dark';
        document.documentElement.dataset.theme = pref;
      })();
    </script>

    <!-- JSON-LD -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />

    <!-- Scroll reveal -->
    <script is:inline>
      (function () {
        if (!('IntersectionObserver' in window)) return;
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('[data-reveal]').forEach(function (el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
